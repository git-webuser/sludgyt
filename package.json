{
  "name": "sludgyt",
  "version": "0.4.1",
  "description": "Terminal-styled desktop GUI wrapper for yt-dlp and ffmpeg",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable --x64",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --universal"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^25.0.0"
  }
}
